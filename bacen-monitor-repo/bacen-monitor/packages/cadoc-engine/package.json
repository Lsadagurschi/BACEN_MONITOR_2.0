{
  "name": "@bacen-monitor/cadoc-engine",
  "version": "1.0.0",
  "private": true,
  "description": "Core engine: parsers, validators e generators para CADOCs do BCB",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./parsers": "./dist/parsers/index.js",
    "./validators": "./dist/validators/index.js",
    "./generators": "./dist/generators/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@bacen-monitor/types": "*",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "@types/node": "^20.0.0"
  }
}
