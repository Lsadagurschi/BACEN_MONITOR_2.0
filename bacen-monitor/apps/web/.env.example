# ============================================================
# BACEN MONITOR — Variáveis de Ambiente
# Copie para .env.local e preencha com seus valores reais
# NUNCA commite o .env.local no git
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe ───────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — criar no dashboard Stripe (Products → Prices)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...
# Preços metered (excedente por operação)
STRIPE_METER_STARTER=price_...
STRIPE_METER_PROFESSIONAL=price_...
STRIPE_METER_ENTERPRISE=price_...

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="BACEN Monitor"

# ── Auth ──────────────────────────────────────────────────────
# Opcional: JWT secret para API Keys internas
API_KEY_SECRET=seu_secret_muito_longo_aqui

# ── Integrações ───────────────────────────────────────────────
# BCB SGS API (público, sem chave necessária)
BCB_SGS_BASE_URL=https://api.bcb.gov.br/dados/serie

# Webhook alertas (opcional — Slack, Teams etc)
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
